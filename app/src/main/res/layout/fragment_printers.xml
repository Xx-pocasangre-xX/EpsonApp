<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_printers.xml
    Pantalla de gestión de impresoras.
    Permite ver, agregar (por discovery o IP manual), renombrar y eliminar impresoras.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="88dp">

            <!-- ── CARD: Info de red del dispositivo ─────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNetworkInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📶 Estado de red"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvDeviceIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📱 IP del dispositivo: …"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/tvNetworkStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Comprobando…"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toca para actualizar"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Botón de discovery ─────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiscover"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔎 Buscar en red"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <!-- Barra de progreso del discovery -->
            <ProgressBar
                android:id="@+id/progressDiscovery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <!-- Mensaje de estado del discovery -->
            <TextView
                android:id="@+id/tvDiscoveryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="12dp"/>

            <!-- Título de la lista -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🖨️ Mis impresoras"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mantén pulsado para predeterminar"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>

            <!-- Lista de impresoras -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPrinters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Estado vacío -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖨️"
                    android:textSize="64sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No hay impresoras guardadas"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usa 'Buscar en red' o el botón ➕\npara agregar una impresora"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB: Agregar por IP manual -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddByIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="➕ Agregar IP"
        app:icon="@drawable/ic_print"
        app:layout_anchorGravity="bottom|end"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>