<?xml version="1.0" encoding="utf-8"?>
<!--
    item_printer.xml
    Ítem individual de la lista de impresoras.
    Muestra: nombre, IP, modelo, método de descubrimiento, estado online, niveles de tinta.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila superior: indicador + nombre + badge predeterminada + menú -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <!-- Indicador online/offline -->
            <View
                android:id="@+id/viewOnlineIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_status"
                android:backgroundTint="@color/status_unknown"
                android:layout_marginEnd="10dp"/>

            <!-- Nombre de la impresora -->
            <TextView
                android:id="@+id/tvPrinterName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Impresora"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Badge "Predeterminada" -->
            <TextView
                android:id="@+id/badgeDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★"
                android:textSize="14sp"
                android:textColor="#F9A825"
                android:layout_marginEnd="6dp"
                android:visibility="gone"/>

            <!-- Botón menú (3 puntos) -->
            <ImageButton
                android:id="@+id/btnPrinterMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Opciones de impresora"/>

        </LinearLayout>

        <!-- IP y puerto -->
        <TextView
            android:id="@+id/tvPrinterIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📡 192.168.1.50:631"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp"/>

        <!-- Modelo -->
        <TextView
            android:id="@+id/tvPrinterModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EPSON L3560 Series"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp"/>

        <!-- Método de descubrimiento -->
        <TextView
            android:id="@+id/tvDiscoveryMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Método: mDNS"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <!-- Divider ligero -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="6dp"/>

        <!-- Fila inferior: estado + tinta + última vez visto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Estado IPP -->
            <TextView
                android:id="@+id/tvPrinterStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Online"
                android:textSize="13sp"
                android:textColor="@color/status_online"
                android:textStyle="bold"/>

            <!-- Última vez visto -->
            <TextView
                android:id="@+id/tvLastSeen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visto: hace 5 min"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <!-- Resumen de niveles de tinta -->
        <TextView
            android:id="@+id/tvInkSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬛75%  🔵80%  🔴65%  🟡90%"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>